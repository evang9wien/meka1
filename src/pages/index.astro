---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

import Hero from '~/components/widgets/Hero.astro';

import BlogTagPosts from '~/components/widgets/BlogTagPosts.astro';
import MekaBilder from '~/parts/startseite/mekabilder.astro';

import Leitbild from '~/parts/startseite/leitbild.astro';
import Pfarrer from '~/parts/startseite/pfarrer.astro';
import Presbyterium from '~/parts/startseite/presbyterium.astro';
import Lektorat from '~/parts/startseite/lektorat.astro';
import Jugendreferentin from '~/parts/startseite/jugendreferentin.astro';
import Gewaltschutz from '~/parts/startseite/gewaltschutz.astro';
import Spenden from '~/parts/angebote/spenden.astro';
import JsonLD from '~/components/common/JsonLD.astro';

const metadata = {
  title: 'Evangelischen Pfarrgemeinde am Alsergrund',
  ignoreTitleTemplate: true,
};

// JSON-LD structured data for the church
const churchSchema = {
  '@type': 'Church',
  name: 'Evangelische Pfarrgemeinde am Alsergrund',
  alternateName: 'Evangelische Kirche 9. Bezirk Wien',
  description: 'Lebendig, einladend, ansprechend - Evangelische Pfarrgemeinde am Alsergrund in Wien',
  url: 'https://evang9.wien',
  telephone: '+43-0699-18877791',
  email: 'stefan.fleischner-janits@evang.at',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Seegasse 16a',
    addressLocality: 'Wien',
    postalCode: '1090',
    addressCountry: 'AT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 48.2233,
    longitude: 16.3641,    
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday'],
      opens: '10:00',
      closes: '11:00',
    },
  ],
  sameAs: [
    'https://www.facebook.com/meka.at',
  ],
};

// Organization schema
const organizationSchema = {
  '@type': 'Organization',
  name: 'Evangelische Pfarrgemeinde am Alsergrund',
  url: 'https://evang9.wien',
  logo: 'https://evang9.wien/astro/Kreuz-bunt.Bwltv7vr.svg',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+43-0699-18877791',
    contactType: 'customer service',
    email: 'stefan.fleischner-janits@evang.at',
    availableLanguage: ['German'],
  },
};
---

<Layout metadata={metadata}>
  <JsonLD schema={churchSchema} slot="head" />
  <JsonLD schema={organizationSchema} slot="head" />

  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Neu hier',
        href: getPermalink('/angebote#neuindergemeinde'),
        icon: 'tabler:mood-plus',
      },
      {
        text: 'Gottesdienste  Termine',
        href: getPermalink('/gottesdienste'),
        icon: 'tabler:cross',
      },
    ]}
    image={{
      src: 'https://res.cloudinary.com/dqjdjviob/image/upload/v1740352856/Homepage/Landing/IMG_0008_hdxntm.jpg',
      alt: 'Eingang Image',
    }}
  >
    <!-- {
        text: 'Taufe & Co',
        href: getPermalink('/kirche'),
        icon: 'tabler:building-church',
      }, -->
    <Fragment slot="title">
      <span class="text-accent dark:text-white highlight">Evangelische</span> Pfarrgemeinde am Alsergrund
    </Fragment>

    <Fragment slot="subtitle">lebendig, einladend, ansprechend</Fragment>
  </Hero>

  <!-- Neuigkeiten -->

  <BlogTagPosts
    title="Neuigkeiten"
    linkText="Alle Neuigkeiten"
    linkUrl={getPermalink('/tag/news')}
    information={`Für weitere Informationen jeweils auf das Bild klicken`}
    tags={['news']}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogTagPosts>

  <!-- Impulse -->
  <BlogTagPosts
    title="Impulse"
    linkText="Alle Impulse"
    linkUrl={getPermalink('/tag/impuls')}
    information={`Für den gesamten Impuls jeweils auf das Bild klicken.`}
    tags={['impuls']}
  />

  <Leitbild />
  <Pfarrer />
  <Presbyterium />

  <Lektorat />
  <Jugendreferentin />
  <Gewaltschutz />
  <MekaBilder />
  <Spenden />
</Layout>
